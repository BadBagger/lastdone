<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:padding="16dp" android:background="#FFF9ED" android:layout_width="match_parent" android:layout_height="match_parent">
 <TextView android:id="@+id/widget_title" android:text="LastDone" android:textStyle="bold" android:textColor="#2D3028" android:textSize="18sp" android:layout_width="match_parent" android:layout_height="wrap_content" />
 <TextView android:id="@+id/widget_elapsed" android:text="Open LastDone to choose an item" android:textColor="#526348" android:textSize="16sp" android:layout_marginTop="8dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
 <Button android:id="@+id/widget_done" android:text="Done Now" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
